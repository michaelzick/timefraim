NODE_ENV=development
APP_ORIGIN=http://127.0.0.1:6173,http://localhost:6173
API_BASE_URL=http://127.0.0.1:4000
PORT=4000
HOST=127.0.0.1
MCP_BEARER_TOKEN=replace-with-a-long-random-token
MCP_READ_ONLY_TOKEN=replace-with-a-second-long-random-token
ALLOWED_EMAIL=you@example.com

SUPABASE_URL=http://127.0.0.1:55331
SUPABASE_ANON_KEY=replace-with-local-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-local-supabase-jwt-secret
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55332/postgres
INTEGRATION_ENCRYPTION_KEY=replace-with-a-long-random-secret

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALENDAR_ID=primary
GOOGLE_PLANNER_CALENDAR_ID=Free Time Tasks

TUNNEL_PUBLIC_BASE_URL=

VITE_APP_ORIGIN=http://127.0.0.1:6173
VITE_API_BASE_URL=http://127.0.0.1:4000
VITE_SUPABASE_URL=http://127.0.0.1:55331
VITE_SUPABASE_ANON_KEY=replace-with-local-supabase-anon-key
VITE_ALLOWED_EMAIL=you@example.com

# Optional: hosted Supabase target for `pnpm dev:linked`.
LINKED_SUPABASE_URL=https://your-project-ref.supabase.co
LINKED_SUPABASE_PUBLISHABLE_KEY=replace-with-linked-publishable-key
LINKED_SUPABASE_SERVICE_ROLE_KEY=replace-with-linked-service-role-key
LINKED_SUPABASE_POSTGRES_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
# Optional unless linked auth access tokens are HS256-signed.
LINKED_SUPABASE_JWT_SECRET=replace-with-linked-jwt-secret
